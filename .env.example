# ─────────────────────────────────────────────────────────────
# aïoly storefront — environment variables
# Copy to .env and fill in. Never commit .env
# All vars are validated by src/lib/env.ts at boot — add new ones there too.
# ─────────────────────────────────────────────────────────────

# Database (SQLite file in dev; postgres URL in prod)
DATABASE_URL="file:./dev.db"

# Environment
NODE_ENV="development"

# Admin auth (single credential). Generate a hash with: npx tsx scripts/hash-password.ts
ADMIN_EMAIL="founder@aioly.eg"
ADMIN_PASSWORD_HASH="$2a$12$REPLACE_ME_WITH_BCRYPT_HASH"

# Session signing (32+ random hex bytes). Generate: openssl rand -hex 32
SESSION_SECRET="replace-with-32-plus-random-hex-bytes"

# Payment provider: "mock" (dev/test) | "paymob" (prod)
PAYMENT_PROVIDER="mock"

# Paymob (Intention API / unified checkout) — sandbox keys for staging
PAYMOB_API_KEY=""
PAYMOB_HMAC_SECRET=""
PAYMOB_INTEGRATION_ID=""
PAYMOB_IFRAME_ID=""
PAYMOB_CENTS_FACTOR="100"

# Reservation TTL: minutes an online-payment order holds stock before sweep releases it
RESERVATION_TTL_MINUTES="30"

# Shipping / pricing config (piasters — EGP × 100)
SHIPPING_FEE_PIASTERS="6000"
FREE_SHIPPING_THRESHOLD_PIASTERS="500000"

# COD availability per shipping country (Egypt on at launch)
COD_ENABLED_COUNTRIES="EG"

# Email provider: "console" (dev) | "resend" (prod)
EMAIL_PROVIDER="console"
RESEND_API_KEY=""
EMAIL_FROM="atelier@aioly.eg"

# Storefront base URL (used for OG images, return URLs, email links)
APP_BASE_URL="http://localhost:3000"
